# MongoDB Connection String
# For local MongoDB: mongodb://localhost:27017/document-signature-app
# For MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/document-signature-app
MONGODB_URI=mongodb://localhost:27017/document-signature-app

# JWT Secret (change this in production)
JWT_SECRET=your-secret-key-change-in-production

# Server Port
PORT=5001
